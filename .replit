modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "freetype", "gst_all_1.gst-plugins-base", "gst_all_1.gstreamer", "lcms2", "libGL", "libGLU", "libcxx", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "mesa", "mtdev", "openjpeg", "pkg-config", "tcl", "tk", "xorg.libX11", "xorg.libXcursor", "xorg.libXext", "xorg.libXfixes", "xorg.libXi", "xorg.libXinerama", "xorg.libXrandr", "xorg.libXrender", "xorg.libXxf86vm", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ELIXIR App"

[[workflows.workflow]]
name = "ELIXIR App"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/src && python main.py"
